# OpenAI API key used by ai_analyzer.py for cost analysis (step ⑤).
# Get one from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the model (defaults to gpt-4o).
OPENAI_MODEL=gpt-4o

# PostgreSQL connection string for storing users + analysis history (step ⑥).
# Works with any Postgres — AWS RDS/Aurora, Azure, or local. If unset, the app
# still runs but history/persistence is disabled.
#   local:  postgresql://postgres:password@localhost:5432/costadviser
#   AWS RDS: postgresql://user:pass@mydb.xxxx.ap-south-1.rds.amazonaws.com:5432/costadviser
DATABASE_URL=postgresql://postgres:password@localhost:5432/costadviser
