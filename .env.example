# ─────────────────────────────────────────────────────────────────────────
# Centralized environment for the AI Cost Adviser (backend + frontend).
#
# Copy this file to .env in the SAME directory (project root):  cp .env.example .env
# Both the FastAPI backend (via python-dotenv) and the Vite frontend (via
# envDir) read this single file.
#
# IMPORTANT: variables the FRONTEND needs MUST be prefixed with VITE_ (Vite only
# exposes VITE_* to the browser). Everything else stays server-side only.
# ─────────────────────────────────────────────────────────────────────────

# ===== Backend: AI analysis (step ⑤) =====
# OpenAI API key. Get one from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# Optional: override the model (defaults to gpt-4o).
OPENAI_MODEL=gpt-4o

# ===== Backend: PostgreSQL for users + analysis history (step ⑥) =====
# Any Postgres works — AWS RDS/Aurora or local. If unset, the app still runs
# but auth/history/persistence is disabled.
DATABASE_URL=postgresql://user:password@host:5432/costadviser

# ===== Backend: JWT auth (step ①) =====
# REQUIRED in production. Generate with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
# Optional: token lifetime in hours (default 24).
JWT_EXPIRE_HOURS=24

# ===== AWS credentials =====
# Do NOT set AWS keys here when running on EC2 with an attached IAM role —
# boto3 fetches temporary credentials from the instance metadata service (IMDS)
# automatically. Only set these for LOCAL development off an instance role:
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
#   AWS_DEFAULT_REGION=us-east-1

# ===== Frontend (must be VITE_ prefixed) =====
# Backend API base URL the browser calls. Defaults to http://localhost:8000.
# On the EC2 host set this to the backend's reachable URL.
VITE_API_BASE=http://localhost:8000
